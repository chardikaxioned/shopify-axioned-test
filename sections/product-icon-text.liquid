{% if section.settings.show-feature == true %}
<div class="product-icon-text-section x-pad_l y-pad_s" style="background-color:{{section.settings.bg-color}};">
<div class="product-text-icon-grid flex align_center flex_wrap justify_center text_left page-width_10 margin_auto">
  <div class="text-block product-icon-block width_20 mob--text_center min-width_200 mob--width_100 x-pad_s mob--x-pad_0">
    <h4 class="y-margin_xs">{{section.settings.heading}}</h4>
  </div>
  {% for block in section.blocks %}
  <div class="mob--x-pad_0 mob--flex_row flex flex_col icon-block product-icon-block y-pad_xs text_center width_20 min-width_200 mob--width_100 x-pad_s">
{% comment%}  {% render 'image', image:block.settings.image, class:"x-pad_m mob--width_33 mob--x-pad_0" %} {%endcomment%}
    <img src="{{block.settings.image | img_url:"master"}}" class="x-pad_m mob--width_33 mob--x-pad_0">
    <h6 class="h8 y-margin_xs color_black">{{block.settings.heading}}</h6>
  </div>
  {%endfor%}
  </div>

</div>
{%endif%}
{% schema %}
  {
    "name": "Product Text Icon",
    "settings": [
{
            "type": "color",
            "id": "bg-color",
            "label": "Block Background Color"
          },
 
{
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
{
            "type": "checkbox",
            "id": "show-feature",
            "label": "Enable Product Features Section"
          }
          
],
    "blocks": [
      {
        "type": "logo-text",
        "name": "Block",
        "settings": [
{
            "type": "image_picker",
            "id": "image",
            "label": "Product image"
          },     
{
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
          }
         
        ]
      }
    ],
    "presets": [
      {
        "name": "Product Text Icons",
        "category": "Custom Section"
        
      }
    ]
  }
{% endschema %}


{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
