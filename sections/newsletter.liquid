{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}
<style>
  .newsletter__wrapper{
  margin:0px !Important;
  }
  @media screen and (min-width: 750px){
  .newsletter-form{
  width:100%;
    max-width:100% !important;
  }
  .newsletter__wrapper .newsletter-form__field-wrapper{
  max-width:100%;
    width:100%;
  }
   
  }
  .newsletter-form__field-wrapper .field__input{
  border-radius:5px;
  }
   .newsletter-form__button{
    width:auto !important;
    }
  
  @media(max-width:750px){
    .newsletter-form__button{
    width:100% !important;   
  margin:20px 0px 0px !important;
    }
  }
</style>

<div class="newsletter center{% if section.settings.full_width == false %} newsletter--narrow page-width{% endif%}" style="background-color:{{section.settings.bg-color}};">
  <div class="y-margin_0 y-pad_m flex flex_wrap justify_between align_center newsletter__wrapper color-{{ section.settings.color_scheme }} gradient" style="background-color:{{section.settings.bg-color}};">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
        {%- when 'paragraph' -%}
    <div class="newsletter-content width_30 flex justify_center align_center text_left min-width_300 mob--min-width_0 flex-gorw_1 mob--width_100">
 <img alt="Paper Place Icon" class="block width_auto" style="margin-right:35px" src="https://cdn.shopify.com/s/files/1/1657/4181/t/26/assets/plane.png?v=53915416277781831921714755517">
