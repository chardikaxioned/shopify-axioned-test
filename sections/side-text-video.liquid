<div class="video-and-text side-video-text flow_hid" style="background-color:{{section.settings.bg_color}};">
  <div class="contant-wrapper page-width"
       {%if section.settings.video_on_left%} style="flex-direction:row-reverse"{%endif%}>  

    <div class="Video-wrapper">
              <div style="overflow:visible;z-index:0;" class="justify_center video--parent flex text-column-video-container align_end {%if section.settings.video_on_left == false%}text_left {% else %} text_right flex_row-rev {%endif%}  ">
                <div class="pos_rel inline_block z-in_3">
                                              <div class="video-icon play-video video-play"></div>
                
                        <img alt="{{ section.settings.image.alt | escape }}" class="text-column-video" src="{{section.settings.image|img_url:"master"}}">

                </div>
                <div class="z-in_2 pos_rel sidevide-product line-height_1 {%if section.settings.video_on_left == false%} sidevideo-product-right {%else %} sidevideo-product-left{%endif%}  ">
                  <div class="z-in_0 sidevideo-product-bg" style="background-color:{{section.settings.bg_product_color}};"></div>{% assign product = all_products[section.settings.product] %}
                  <a class="block pos_rel z-in_2 f9 color_black text_center" href="{{product.url}}"> <img alt="{{ product.featured_image.alt | escape }}" src="{{product.featured_image | img_url:"master"}}"></a>
                  <p class="z-in_2 pos_rel text_center line-height_1" style="margin:0px;"><a class="pos_rel f9 color_black text_center" href="{{product.url}}">{{section.settings.prodname}}</a></p>
                </div>
              
      </div>
      
      
      {% if section.settings.video_url contains 'youtu.be' %}
{% assign v_id = section.settings.video_url | split: 'be/' | last %}
{% capture v_url %}https://www.youtube.com/embed/{{ v_id }}?rel=0&showinfo=0&vq=720{% endcapture %}
{% elsif section.settings.video_url contains 'youtube.com' %}
{% assign v_id = section.settings.video_url | split: '?v=' | last %}
{% capture v_url %}https://www.youtube.com/embed/{{ v_id }}?rel=0&showinfo=0&vq=720{% endcapture %}
{% elsif section.settings.video_url contains 'vimeo.com' %}
{% assign v_id = section.settings.video_url | split: '.com/' | last %}
{% capture v_url %}//player.vimeo.com/video/{{ v_id }}?byline=0&portrait=0&badge=0{% endcapture %}
{% endif %}


<div class="video-ratio video-ratio_modal">
                                                <div class="close-video close-video-cross"><svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" fill="none" viewBox="0 0 18 17">
  <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
</svg>
</div>

                                                <div class="close-video close-video-bg"></div>

<iframe src="{{v_url}}"></iframe>
</div>
      
      
    </div>

    <div class="text-wrapper "> 

      <div class="star-wrapper ">
        <img alt="Star Reviews Icon" src="{{"star.png" | asset_url }}">
      </div>
      <h3 class="f3 y-margin_xs line-height_1">{{section.settings.head}}</h3>
      <p class="p">{{section.settings.text|newline_to_br}}</p>
      
              <p class="f9  weight_500 y-margin_0">{{section.settings.name}}</p>

      
    </div>
  </div>
</div> 


<style>
  .text-wrapper{
      text-align: center;
        max-width: 350px;
    margin: auto;
  }
  
  .Video-wrapper{
  flex-basis:50%;
    text-align: center;
  }

  .Video-wrapper img{
  border-radius:50%;
      width: 280px;
    height: 280px;
  }  
  .Video-wrapper html{
  border-radius:50%;
        width: 280px;
    height: 280px;
  }
  
  .text-wrapper{
   flex-basis:50%;
      
  }
  
  
  .video-and-text{
   
    background-repeat: no-repeat;
    background-size: cover;
  }
  .contant-wrapper{
  display:flex;
        align-items: center;
  }

  .contant-wrapper{
  padding-top: 40px;
    padding-bottom: 40px;  
  }
  
  @media(max-width:768px){
    .contant-wrapper{
    
    flex-direction: column !important;
    }
    .text-wrapper{
    padding-top:60px;
    }
  } 
  
  
</style>


{% schema %}
{
"name": "Side Video Text",
"settings": [

{
  
"type": "color",
  
"id": "bg_color",
  
"label": "Background",
  
"default": "#000000"
},
{
  
"type": "color",
  
"id": "bg_product_color",
  
"label": "Product Circle Color" 
},
{
  
"type": "checkbox", 
"id": "video_on_left",
  
"label": "video_on_right",
  
"default": true
},
{
"type": "video_url",
"id": "video_url",
"label": "Video url",
"accept": [
"youtube",
"vimeo"
]
},
{
"type":"product",
"id":"product",
"label":"Select Product"
},
{
"type":"text",
"id":"prodname",
"label":"Enter Product Name"
},
{
"type":"text",
"id":"name",
"label":"Add Customer Name"
},
{
"type":"image_picker",
"id":"image",
"label":"Image"
},
{
"type":"text",
"id":"head",
"label":"Add Heading"
},

{
"type":"textarea",
"id":"text",
"label":"Add Text"
}



],
"presets":[
{
"name":"Side Text Video",
"category":"custom"

}]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
  