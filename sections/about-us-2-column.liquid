<div class="three-column-section y-pad_m ">
<div class="three-column-grid flex page-width_12 flex_wrap align_center">
  

  <div class="three-column-blocks-container width_50 x-pad_xl flex-grow_1 mob--width_100 min-width_300 mob--min-width_0">
  <h2 class="f4" style="margin-bottom:15px;">{{section.settings.heading}}</h2>
   <div class="f9 child-inherit page-width_7 ">{{section.settings.description}}</div>
     
  </div>
    
  <div class="product-3col-rightimg width_30 x-pad_s mob--width_100  mob--min-width_0 ">
{% comment %}{% render 'image', image:section.settings.image-right, class:"" %} {%endcomment %}
<img class="width_100" src="{{section.settings.image-right | img_url:"master"}}">
    </div>
  
  
  </div>


</div>
{% schema %}
  {
    "name": "About Us 2 Column",
    "settings": [
  {
  "type":"text",
  "id":"heading",
  "label":"Enter Heading"
  },
  {
  "type":"richtext",
  "id":"description",
  "label":"Enter description"
  },
  
  {
  "type":"image_picker",
  "id":"image-right",
  "label":"Select Right Image"
  }
],
  "presets":[
  {
  "category":"Custom Section",
  "name":"About Us 2 Column"
  }
  ]
  }
{% endschema %}

