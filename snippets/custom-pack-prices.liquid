{% assign turmeric_3pack = 4322 %}
{% assign turmeric_5pack = 7187 %}
{% assign turmeric_data = turmeric | append: ':' | append: turmeric_1pack | append: ',' | append: turmeric_2pack | append: ',' | append: turmeric_3pack | append: ',' | append: turmeric_5pack %}
{% assign custom_prices = custom_prices | push: turmeric_data %}

