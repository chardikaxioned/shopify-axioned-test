{% comment %}
  Custom pack prices for each product
  Use product handle as the key for easy reference
{% endcomment %}

{% assign custom_prices = "" | split: "" %}

{% comment %} Elderberry {% endcomment %}
{% assign elderberry = "elderberry-gummies" %}
{% assign elderberry_1pack = 0 %}
{% assign elderberry_2pack = 31.92 %}
{% assign elderberry_3pack = 41.99 %}
{% assign elderberry_5pack = 70.04 %}
{% assign elderberry_data = elderberry | append: ':' | append: elderberry_1pack | append: ',' | append: elderberry_2pack | append: ',' | append: elderberry_3pack | append: ',' | append: elderberry_5pack %}
{% assign custom_prices = custom_prices | push: elderberry_data %}

